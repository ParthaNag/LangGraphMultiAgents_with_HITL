# Google AI Studio — required for Gemini provider (default)
# Get your key at https://aistudio.google.com/apikey
GOOGLE_AISTUDIO_API_KEY=your_google_aistudio_api_key_here

# Tavily — required for web search
# Get your key at https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# OpenRouter — optional, required only if using the OpenRouter provider
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
